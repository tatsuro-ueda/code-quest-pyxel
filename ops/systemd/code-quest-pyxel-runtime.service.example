[Unit]
Description=Block Quest Pyxel public runtime
After=network.target

[Service]
Type=simple
WorkingDirectory=<PROJECT_ROOT>
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/python3 <PROJECT_ROOT>/tools/web_runtime_server.py --host 0.0.0.0 --port 8888
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
